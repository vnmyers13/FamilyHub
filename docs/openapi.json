              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "synced_count": {
                      "type": "integer"
                    },
                    "last_sync": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },

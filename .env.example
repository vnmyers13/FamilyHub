# FamilyHub Environment Configuration
# Copy this file to .env and fill in your values

# General
FAMILY_NAME=The Smith Family
TIMEZONE=America/Chicago

# FastAPI Backend
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=familyhub.local,localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://familyhub:familyhub_password@postgres:5432/familyhub

# Google Calendar Integration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://familyhub.local/api/auth/google/callback

# Push Notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Email (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@familyhub.local

# Backup Configuration
BACKUP_RETENTION_DAYS=30

# Photos
PHOTOS_PATH=/data/photos
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO

# Development only
MOCK_GOOGLE_CALENDAR=False

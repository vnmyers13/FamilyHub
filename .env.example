# FamilyHub Environment Configuration
# Copy this file to .env and fill in your values
#
# Generate a SECRET_KEY: python -c "from secrets import token_urlsafe; print(token_urlsafe(32))"

# ── General ──────────────────────────────────────────────
FAMILY_NAME=The Smith Family
TIMEZONE=America/Chicago

# ── FastAPI Backend ──────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://familyhub.local,http://localhost:5173,http://localhost:3000
DEBUG=False

# ── Database (SQLite for Phase 1-3, PostgreSQL optional in Phase 4) ──
DATABASE_URL=sqlite+aiosqlite:////data/db/familyhub.db

# ── Google Calendar Integration ──────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://familyhub.local/api/auth/google/callback

# ── Microsoft Calendar Integration ───────────────────────
# Get credentials from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_OAUTH_CLIENT_ID=your-microsoft-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_OAUTH_REDIRECT_URI=https://familyhub.local/api/auth/microsoft/callback

# ── Weather Integration ──────────────────────────────────
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_UNITS=imperial

# ── Push Notifications (Web Push / VAPID) ───────────────
# Generate keys: pip install webpush; python -c "from webpush import generate_vapid_key; print(generate_vapid_key())"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Email (optional, for notifications) ──────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@familyhub.local

# ── Backup Configuration ─────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00

# ── Photos ───────────────────────────────────────────────
PHOTOS_PATH=/data/photos
MAX_UPLOAD_SIZE_MB=100

# ── Wall Display ─────────────────────────────────────────
WALL_IDLE_TIMEOUT_SECONDS=300

# ── Calendar Sync ────────────────────────────────────────
CALENDAR_SYNC_INTERVAL_MINUTES=15

# ── Development Only ─────────────────────────────────────
MOCK_GOOGLE_CALENDAR=False
MOCK_MICROSOFT_CALENDAR=False
